{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Resolve the package's own "#*" subpath imports (package.json "imports")
    // to source under the "development" condition — the same condition tsx
    // passes at dev/migrate/test time. The compiled build drops the condition
    // and falls through to "./build/esm/*" (see package.json).
    "customConditions": ["development"],
    // No baseUrl (deprecated in TS 6): paths resolve relative to this file.
    "paths": {
      "@landline/domain": ["../domain/src/index.js"],
      "@landline/domain/*": ["../domain/src/*.js"]
    }
  }
}
